coal_share_elec = "Coal",
gas_share_elec  = "Gas",
oil_share_elec  = "Oil"
))
p2 <- ggplot(uk_fossil_long, aes(x = year, y = share, fill = source)) +
geom_area(alpha = 0.8, colour = "white", linewidth = 0.3) +
scale_fill_manual(values = c(
