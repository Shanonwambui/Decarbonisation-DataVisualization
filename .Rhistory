"uk_fossil_fuel_consumption.png",
plot = p2,
width = 12,
height = 7,
dpi = 300,
bg = "transparent"
)
label_years <- seq(2000, 2025, 5)
uk_scatter <- uk_electricity %>%
filter(!is.na(carbon_intensity_elec), !is.na(fossil_share_elec)) %>%
mutate(label = if_else(year %in% label_years,
as.character(year), NA_character_))
p4 <- ggplot(uk_scatter, aes(x = fossil_share_elec, y = carbon_intensity_elec)) +
geom_smooth(method = "lm", se = TRUE,
colour = "#2980b9",
fill = "#aed6f1",
alpha = 0.3,
linewidth = 0.7) +
geom_path(colour = "grey70",
linewidth = 0.6,
linetype = "dotted") +
geom_point(aes(colour = year),
size = 4) +
geom_text_repel(
aes(label = label),
size = 4,
colour = "grey20",
box.padding = 0.5,
point.padding = 0.3,
max.overlaps = 10
) +
scale_colour_gradient(
low = "#f39c12",
high = "#1a252f",
name = "Year"
) +
scale_x_continuous(labels = label_percent(scale = 1)) +
labs(
title    = "Fossil Fuel Share vs Carbon Intensity",
subtitle = "Reducing fossil fuels leads to lower emissions",
x        = "Fossil fuel share (%)",
y        = "Carbon intensity (gCO2/kWh)"
) +
theme_minimal(base_size = 18) +
theme(
# Titles
plot.title    = element_text(size = 24, face = "bold"),
plot.subtitle = element_text(size = 18, colour = "grey40"),
# Axis
axis.text  = element_text(size = 14),
axis.title = element_text(size = 16),
# Legend
legend.position = "right",
legend.title    = element_text(size = 14),
legend.text     = element_text(size = 12),
# Clean look
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
# Caption
plot.caption = element_text(size = 12, colour = "grey40"),
# Transparent
plot.background  = element_rect(fill = "transparent", colour = NA),
panel.background = element_rect(fill = "transparent", colour = NA)
)
p4
ggsave(
"uk_carbon_intensity.png",
plot = p4,
width = 12,
height = 7,
dpi = 300,
bg = "transparent"
)
