aes(y = low_carbon_share,
label = "2017: Low-carbon overtakes fossil fuels"),
size = 5,
fontface = "bold",
colour = "#27AE60",
nudge_y = 30
) +
# Colour palette (consistent with poster)
scale_colour_manual(values = c(
"Fossil fuels" = "#C0392B",   # red
"Low-carbon"   = "#27AE60"    # green
)) +
# Axes
scale_x_continuous(breaks = seq(2000, 2025, 5)) +
scale_y_continuous(
labels = label_percent(scale = 1),
limits = c(0, 100)
) +
# Labels (simplified for non-expert audience)
labs(
title    = "UK Electricity Transition",
subtitle = "Low-carbon energy overtook fossil fuels in 2017 and continues
to grow.",
x        = NULL,
y        = "Share of electricity (%)",
colour   = NULL
) +
# CLEAN POSTER THEME
theme_minimal(base_size = 18) +
theme(
# Titles
plot.title    = element_text(size = 26, face = "bold"),
plot.subtitle = element_text(size = 16, colour = "grey40"),
# Axis text
axis.text  = element_text(size = 14),
axis.title = element_text(size = 16),
# Legend
legend.position = "top",
legend.text     = element_text(size = 14),
# Remove clutter
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
# Caption
plot.caption = element_text(size = 12, colour = "grey40"),
# ✅ TRANSPARENT BACKGROUND
plot.background  = element_rect(fill = "transparent", colour = NA),
panel.background = element_rect(fill = "transparent", colour = NA)
)
p
label_years <- seq(2000, 2025, 5)
uk_trend <- uk_electricity %>%
mutate(label = if_else(year %in% label_years,
as.character(year), NA_character_))
label_2017 <- uk_trend %>%
filter(year == 2017)
p <- ggplot(uk_trend, aes(x = year)) +
# Lines (thicker for poster visibility)
geom_line(aes(y = fossil_share_elec, colour = "Fossil fuels"),
linewidth = 1.5) +
geom_line(aes(y = low_carbon_share, colour = "Low-carbon"),
linewidth = 1.5) +
# Points (slightly bigger)
geom_point(aes(y = fossil_share_elec, colour = "Fossil fuels"),
size = 3) +
geom_point(aes(y = low_carbon_share, colour = "Low-carbon"),
size = 3) +
# Vertical line (more subtle but visible)
geom_vline(xintercept = 2017,
linetype = "dashed",
colour = "grey40",
linewidth = 1) +
# Annotation (clear + readable)
geom_text_repel(
data = label_2017,
aes(y = low_carbon_share,
label = "2017: Low-carbon overtakes fossil fuels"),
size = 5,
fontface = "bold",
colour = "#27AE60",
nudge_y = 30
) +
# Colour palette (consistent with poster)
scale_colour_manual(values = c(
"Fossil fuels" = "#C0392B",   # red
"Low-carbon"   = "#27AE60"    # green
)) +
# Axes
scale_x_continuous(breaks = seq(2000, 2025, 5)) +
scale_y_continuous(
labels = label_percent(scale = 1),
limits = c(0, 100)
) +
# Labels (simplified for non-expert audience)
labs(
title    = "UK Electricity Transition",
subtitle = "Low-carbon energy overtook fossil fuels in 2017 and continues
to grow.",
x        = NULL,
y        = "Share of electricity (%)",
colour   = NULL
) +
# CLEAN POSTER THEME
theme_minimal(base_size = 18) +
theme(
# Titles
plot.title    = element_text(size = 26, face = "bold"),
plot.subtitle = element_text(size = 16, colour = "grey40"),
# Axis text
axis.text  = element_text(size = 14),
axis.title = element_text(size = 16),
# Legend
legend.position = "top",
legend.text     = element_text(size = 14),
# Remove clutter
panel.grid.minor = element_blank(),
panel.grid.major.x = element_blank(),
# Caption
plot.caption = element_text(size = 12, colour = "grey40"),
# ✅ TRANSPARENT BACKGROUND
plot.background  = element_rect(fill = "transparent", colour = NA),
panel.background = element_rect(fill = "transparent", colour = NA)
)
p
ggsave(
"uk_transition_plot.png",
plot = p,
width = 12,
height = 7,
dpi = 300,
bg = "transparent"
)
uk_fossil_long <- uk_electricity %>%
select(year, coal_share_elec, gas_share_elec, oil_share_elec) %>%
pivot_longer(-year, names_to = "source", values_to = "share") %>%
